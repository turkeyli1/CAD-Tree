#1349 = ( NAMED_UNIT(*) SI_UNIT($,.STERADIAN.) SOLID_ANGLE_UNIT() );
#1350 = UNCERTAINTY_MEASURE_WITH_UNIT(LENGTH_MEASURE(1.E-02),#1347,
  'distance_accuracy_value','confusion accuracy');
#1351 = PRODUCT_RELATED_PRODUCT_CATEGORY('part',$,(#7));
ENDSEC;
END-ISO-10303-21;
